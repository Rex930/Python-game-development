# Count the occerrences of each alphabet  in the input string entered by the user.
inputstr= input("Enter the string: ")
charCount = {}
for c in inputstr:
    if c.isalpha():
        if c in charCount:
            charCount[c] += 1
        else:
            charCount[c] = 1
print (charCount)